<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_shipment_report_wizard" model="ir.ui.view">
        <field name="name">import.shipment.report.wizard.form</field>
        <field name="model">import.shipment.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Shipment Report">
                <group>
                    <field name="shipment_ids" widget="many2many_tags" readonly="1"/>
                </group>
                <footer>
                    <button name="action_generate_excel" type="object" string="Excel İndir" class="oe_highlight"/>
                    <button string="İptal" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_shipment_report_wizard" model="ir.actions.act_window">
        <field name="name">Import Shipment Report</field>
        <field name="res_model">import.shipment.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
