<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_normal_form_view_inherit_manufacturer" model="ir.ui.view">
        <field name="name">product.product.form.inherit.manufacturer</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_code']" position="after">
                <field name="x_manufacturer_code"/>
            </xpath>
        </field>
    </record>

    <record id="product_product_tree_view_inherit_manufacturer" model="ir.ui.view">
        <field name="name">product.product.tree.inherit.manufacturer</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_code']" position="after">
                <field name="x_manufacturer_code"/>
            </xpath>
        </field>
    </record>
</odoo>
