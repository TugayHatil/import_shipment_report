<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_shipment_excel_wizard_form" model="ir.ui.view">
        <field name="name">import.shipment.excel.wizard.form</field>
        <field name="model">import.shipment.excel.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Shipment from Excel">
                <group>
                    <field name="partner_id"/>
                    <field name="file" filename="file_name"/>
                    <field name="file_name" invisible="1"/>
                </group>
                <footer>
                    <button name="action_import" string="Upload &amp; Preview" type="object" class="btn-primary"/>
                    <button name="action_confirm_import" string="Confirm &amp; Create Picking" type="object" class="btn-success"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_shipment_excel_wizard" model="ir.actions.act_window">
        <field name="name">Import Shipment Excel</field>
        <field name="res_model">import.shipment.excel.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
